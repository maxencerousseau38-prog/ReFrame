# ── Valoryx environment ──────────────────────────────────────────────────────
# Copy to .env.local and fill in. The MVP renders fully without these (it uses
# the deterministic mock intelligence layer in lib/data.ts).

# Supabase (auth + Postgres + Edge Functions)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM provider powering the analysis pipeline (server-side only)
ANTHROPIC_API_KEY=

# ── Company data providers (server-side only) ──
# Private French companies (Pappers aggregates INSEE Sirene + INPI + BODACC)
PAPPERS_API_KEY=
INSEE_SIRENE_TOKEN=
# Listed companies (Financial Modeling Prep-style market data API)
MARKET_DATA_API_KEY=
# Funding rounds enrichment (optional)
CRUNCHBASE_API_KEY=

# LLM model id for the qualitative layer (phase 2)
ANTHROPIC_MODEL=claude-opus-4-8

# Billing
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
