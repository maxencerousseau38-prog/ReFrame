# ── Valoryx environment ──────────────────────────────────────────────────────
# Copy to .env.local and fill in. The MVP renders fully without these (it uses
# the deterministic mock intelligence layer in lib/data.ts).

# Supabase (auth + Postgres + Edge Functions)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM provider powering the analysis pipeline (server-side only)
ANTHROPIC_API_KEY=

# External data enrichment (legal / financial), server-side only
INPI_API_KEY=
PAPPERS_API_KEY=

# Billing
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
